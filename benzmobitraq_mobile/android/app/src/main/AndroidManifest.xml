<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- LOCATION PERMISSIONS -->
    <!-- Fine location for GPS -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Coarse location as fallback -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Background location (Android 10+) - CRITICAL for tracking -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    
    <!-- FOREGROUND SERVICE PERMISSIONS -->
    <!-- Required for background location tracking -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Android 14+: declaring the data-sync type explicitly so queued location
         points + offline expenses can be uploaded by the same foreground service
         once internet returns, without the OS killing the service mid-sync. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    
    <!-- WAKE LOCK - Keep CPU alive during tracking -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- BOOT COMPLETED - Optional: Resume tracking after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- INTERNET for Supabase -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- NOTIFICATION - Required on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- BATTERY OPTIMIZATION - Request to be exempted -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- VIBRATION - For tracking-stalled alerts (3x vibration pattern) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- FULL SCREEN INTENT — required on Android 14+ so the stationary
         alarm can rise over the lock screen like a clock-alarm
         instead of staying as a silent tray entry the user misses. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- SCHEDULE_EXACT_ALARM - For tracking watchdog on Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    
    <!-- SENSORS for motion detection -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />

    <!-- ACTIVITY RECOGNITION — required for ActivityRecognition API
         (driving vs walking detection). Without this declared, the
         OS rejects permission requests silently — Grant button does
         nothing. Added 2026-05-17 after user reported buttons not
         opening anything. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION" />

    <application
        android:label="Benz Packaging: Employee"
        android:name="${applicationName}"
        android:icon="@mipmap/launcher_icon"
        android:enableOnBackInvokedCallback="true">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            
            <!-- Deep Link for Supabase Auth -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="io.supabase.flutter" android:host="login-callback" />
            </intent-filter>
        </activity>
        
        <!-- Background Service for Location Tracking -->
        <!-- stopWithTask=false: keep service alive even if user swipes the app away (VPN-style) -->
        <!-- The foregroundServiceType is intentionally a combination:
              - "location" : required to keep receiving GPS in background
              - "dataSync" : required on Android 14+ to upload location points
                             and offline expense queue while the service runs.
             Without dataSync, Android 14 silently restricts the service from
             doing the Supabase work it needs to do after location runs.
             stopWithTask=false ensures swiping the app from recents does
             NOT stop the tracking service — same behavior as VPN apps. -->
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:foregroundServiceType="location|dataSync"
            android:exported="false"
            android:stopWithTask="false"
            tools:node="replace">
        </service>

        <!-- Boot Receiver - Resume tracking after device restart -->
        <receiver
            android:name="id.flutter.flutter_background_service.BootReceiver"
            android:enabled="true"
            android:exported="false"
            tools:node="replace">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        
        <!-- Firebase Messaging Service -->
        <service
            android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        
        <!-- Notification Channel Metadata -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="high_importance_channel" />
        
        <!-- Don't delete meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Google Maps API Key for nearby company search -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyD2EH4_Gv6tP3qS1Ue70gLfyoOZT9eIciM" />

        <!-- DISABLE IMPELLER: Known to cause freezes on some devices -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />

    </application>
    
    <!-- QUERIES — Android 11+ requires apps to declare which intents
         they query, otherwise resolveActivity() returns null and our
         "open settings" deep links silently fail (which is the bug
         the user hit on 2026-05-17: tapping Battery / Activity
         Recognition / Notifications Grant buttons did nothing). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <!-- Google Maps & Maps Go (for "Open in Google Maps" deep link) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="google.navigation" />
        </intent>
        <!-- Every Android Settings deep link we use -->
        <intent>
            <action android:name="android.settings.APPLICATION_DETAILS_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.settings.IGNORE_BATTERY_OPTIMIZATION_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.settings.LOCATION_SOURCE_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.settings.APP_NOTIFICATION_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
        </intent>
        <intent>
            <action android:name="android.settings.MANAGE_APP_ALL_FILES_ACCESS_PERMISSION" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

</manifest>
